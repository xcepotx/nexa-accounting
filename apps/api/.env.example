APP_NAME=Nexa Accounting API
APP_ENV=production
PORT=8650
INTERNAL_API_KEY=change-this-key
EVENT_STORE_PATH=/data/accounting/app/nexa-accounting/data/events/pos_events.jsonl
NEXAPOS_BASE_URL=https://nexapos.contentfactory.click
PUBLIC_WEB_URL=https://acc.contentfactory.click
JOURNAL_DRAFT_STORE_PATH=/data/accounting/app/nexa-accounting/data/journal_drafts.jsonl
SIM_LEDGER_ENTRY_STORE_PATH=/data/accounting/app/nexa-accounting/data/sim_ledger_entries.jsonl
SIM_LEDGER_LINE_STORE_PATH=/data/accounting/app/nexa-accounting/data/sim_ledger_lines.jsonl
EVENT_DEAD_LETTER_STORE_PATH=/data/accounting/app/nexa-accounting/data/dead_letter_events.jsonl
CHART_OF_ACCOUNTS_STORE_PATH=/data/accounting/app/nexa-accounting/data/chart_of_accounts.json
ACCOUNT_MAPPING_STORE_PATH=/data/accounting/app/nexa-accounting/data/account_mappings.json
LEDGER_DB_PATH=/data/accounting/app/nexa-accounting/data/nexa_accounting_ledger.db
ACCOUNTING_AUTH_SECRET_KEY=change-this-auth-secret
ACCOUNTING_TOKEN_TTL_SECONDS=86400
ACCOUNTING_OWNER_EMAIL=owner@nexa-accounting.local
ACCOUNTING_OWNER_PASSWORD=change-this-owner-password
APP_USER_STORE_PATH=/data/accounting/app/nexa-accounting/data/app_users.json
